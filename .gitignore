# Ignorar archivos de audio (Gestión local según Opción A)
# --- Multimedia ---
# Ignoramos el contenido de media pero NO la carpeta en sí
media/*.mp3
media/*.wav
media/*.flac
media/*.m4a

# --- Base de Datos y Binarios ---
# Ignoramos la DB local para que no se sobreescriba en GitHub
radio_core.db
*.db-journal
*.db-wal
*.db-shm

# Librerías binarias (Respaldar por fuera)
bass.dll
libbass.so
libbass.dylib

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
.env
venv/
env/

# --- IDEs y Sistema ---
.vscode/
.idea/
.DS_Store
Thumbs.db

# --- Carpetas Temporales ---
Nueva\ Carpeta/
temp/